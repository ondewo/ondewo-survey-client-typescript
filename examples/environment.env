# ONDEWO Survey Typescript client SDK -- examples configuration TEMPLATE.
#
# Loaded automatically by every runnable example via dotenv (see survey-list-app.ts).
# This is a NON-SECRET template committed to the repo: keep real credentials OUT of
# version control (leave the secret values blank here and set them in your shell/CI).

# --- Connection ---------------------------------------------------------------
# Host and port of the ONDEWO Survey gRPC-web endpoint (Envoy proxy).
ONDEWO_HOST=localhost
ONDEWO_PORT=443
# Use a TLS (https) gRPC-web channel (true) or plaintext http (false).
ONDEWO_USE_SECURE_CHANNEL=true

# --- Keycloak (D18 offline-token auth) ---------------------------------------
# Base Keycloak URL, realm and PUBLIC SDK client id used for the ROPC login.
KEYCLOAK_URL=https://auth.example.com/auth
KEYCLOAK_REALM=ondewo-ccai-platform
KEYCLOAK_CLIENT_ID=ondewo-survey-cai-sdk-public
# Only needed for a confidential client; the public SDK client above requires none.
KEYCLOAK_CLIENT_SECRET=
# 2FA-exempt technical-user credentials for the headless login.
KEYCLOAK_USER_NAME=technical-user@example.com
KEYCLOAK_PASSWORD=
# Verify the Keycloak TLS certificate (set false ONLY for a self-signed local Envoy).
KEYCLOAK_VERIFY_SSL=true
