{
	"name": "@ondewo/survey-client-typescript",
	"version": "2.0.0",
	"description": "ONDEWO Survey (SURVEY) Client library for Typescript",
	"author": "ONDEWO GmbH <office@ondewo.com>",
	"homepage": "https://ondewo.com",
	"license": "Apache-2.0",
	"keywords": [
		"ondewo",
		"survey",
		"api",
		"client",
		"typescript",
		"grpc"
	],
	"main": "public-api.js",
	"typings": "public-api.d.ts",
	"scripts": {
		"pretest": "tsc auth/offlineTokenProvider.ts auth/offlineTokenProvider.spec.ts --ignoreConfig --module commonjs --target es2020 --strict --lib es2020,dom --skipLibCheck --sourceMap --types node --typeRoots ./node_modules/@types --outDir .test-build",
		"test": "c8 --check-coverage --lines 100 --branches 100 --functions 100 --include '**/offlineTokenProvider.js' --exclude '**/*.spec.js' --reporter text node --test .test-build/offlineTokenProvider.spec.js"
	},
	"repository": {
		"type": "git",
		"directory": "https://github.com/ondewo/ondewo-survey-client-typescript"
	},
	"dependencies": {
		"google-protobuf": "3.21.4",
		"grpc-web": "^1.5.0",
		"tslib": "^2.8.1"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.1.0",
		"@eslint/js": "^9.14.0",
		"@types/node": "^20.12.14",
		"@typescript-eslint/eslint-plugin": "^8.13.0",
		"c8": "^11.0.0",
		"dotenv": "^16.4.5",
		"eslint": "^9.14.0",
		"global": "^4.4.0",
		"husky": "^9.1.6",
		"prettier": "^3.3.3",
		"typescript": "^6.0.3"
	}
}
